{
  "name": "@chaafoo/anchored-mcp",
  "version": "0.3.0",
  "description": "MCP server and CLI for the anchored Claude Code plugin — typed task-file state mutations with schema validation",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "anchored-mcp": "./dist/mcp/server.js",
    "anchored": "./dist/cli/bin.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chafoo/anchored.git",
    "directory": "mcp"
  },
  "homepage": "https://github.com/chafoo/anchored#readme",
  "bugs": {
    "url": "https://github.com/chafoo/anchored/issues"
  },
  "license": "MIT",
  "author": {
    "name": "chafoo",
    "url": "https://github.com/chafoo"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "claude",
    "anthropic",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "anchored",
    "task-management",
    "autonomous-agents",
    "autonomous-ai-coding",
    "ai-agents",
    "coding-agent",
    "agentic",
    "agent-orchestration",
    "agent-workflow",
    "subagents",
    "spec-driven-development",
    "tdd",
    "llm"
  ],
  "scripts": {
    "build": "node build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli/bin.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-coverage": "type-coverage --strict --at-least 95 --detail --ignore-files 'tests/**' --ignore-files 'scripts/**' --ignore-files 'build.mjs'",
    "prepare": "cd .. && husky mcp/.husky 2>/dev/null || true",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build",
    "version": "node ../scripts/sync-plugin-version.cjs && git add ../plugin/.claude-plugin/plugin.json"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "size-limit": [
    {
      "name": "CLI bundle (anchored)",
      "path": "dist/cli/bin.js",
      "limit": "800 KB"
    },
    {
      "name": "MCP server bundle (anchored-mcp)",
      "path": "dist/mcp/server.js",
      "limit": "800 KB"
    }
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.1.0",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.5.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@size-limit/file": "^11.2.0",
    "@types/node": "^20.14.0",
    "@types/proper-lockfile": "^4.1.4",
    "esbuild": "^0.23.0",
    "eslint": "^9.15.0",
    "husky": "^9.1.7",
    "license-checker": "^25.0.1",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.0",
    "size-limit": "^11.1.6",
    "tsx": "^4.19.0",
    "type-coverage": "^2.29.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.0"
  }
}
