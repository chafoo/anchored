// src/lib/utils/error.ts
function anchoredError(kind, message, suggestions) {
  const e = new Error(message);
  e.name = kind;
  e.kind = kind;
  if (suggestions)
    e.suggestions = suggestions;
  return e;
}

// src/services/store/store.ts
import { dirname as dirname2 } from "node:path";

// src/services/store/scope/safe-write.ts
import { dirname } from "node:path";
async function safeWrite(deps, path, content, expectedVersion) {
  const { fs, lock, rand, pid } = deps;
  await fs.mkdir(dirname(path), { recursive: true });
  let release;
  try {
    release = await lock.acquire(path);
  } catch (e) {
    throw anchoredError("WriteContention", `could not acquire write lock for ${path}: ${e.message}`, ["another process holds the lock — retry shortly"]);
  }
  try {
    if (expectedVersion !== undefined && fs.stat) {
      const current = await fs.stat(path);
      if (current !== undefined && current !== expectedVersion) {
        throw anchoredError("WriteContention", `${path} changed since it was read (concurrent write) — no write performed`, ["re-read the node and retry the mutation on the fresh state"]);
      }
    }
    const tmp = `${path}.tmp.${String(pid())}.${rand()}`;
    await fs.writeFile(tmp, content);
    await fs.rename(tmp, path);
  } finally {
    await release();
  }
}

// src/services/store/store.ts
var VERSION = Symbol("anchored.version");
function createStore(deps) {
  const { fs, lock, yaml, pathFor, archivePathFor, rand, pid } = deps;
  return {
    async read(slug, schema) {
      const path = pathFor(slug);
      const data = yaml.parse(await fs.readFile(path), { maxAliasCount: 0 });
      const node = schema.parse(data);
      if (fs.stat) {
        const v = await fs.stat(path);
        if (v !== undefined)
          node[VERSION] = v;
      }
      return node;
    },
    async write(slug, node, schema) {
      schema.parse(node);
      const content = yaml.stringify(node, { lineWidth: 0 });
      const expectedVersion = node[VERSION];
      await safeWrite({ fs, lock, rand, pid }, pathFor(slug), content, expectedVersion);
      return node;
    },
    async archive(slug) {
      const { from, to } = archivePathFor(slug);
      await fs.mkdir(dirname2(to), { recursive: true });
      await fs.rename(from, to);
    },
    async remove(slug) {
      await fs.unlink(pathFor(slug));
    }
  };
}

