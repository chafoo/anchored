function configError(message) {
  const e = new Error(message);
  e.name = "ConfigError";
  return e;
}
function mergeSteps(def, user) {
  const result = def.map((s) => ({ ...s }));
  for (const raw of user) {
    const us = raw;
    const idx = result.findIndex((s) => s.name === us.name);
    if (idx >= 0) {
      const existing = result[idx];
      if (existing.use !== undefined && us.use !== undefined) {
        throw configError(`step '${String(us.name)}' is a built-in — extend it with instructions only; its worker cannot be redefined`);
      }
      const rest = { ...us };
      delete rest.before;
      delete rest.after;
      delete rest.instructions;
      const merged = { ...existing, ...rest };
      if (typeof us.instructions === "string") {
        merged.instructions = typeof existing.instructions === "string" ? `${existing.instructions}
${us.instructions}` : us.instructions;
      }
      result[idx] = merged;
    } else {
      const step = { ...us };
      delete step.before;
      delete step.after;
      let pos = result.length;
      if (typeof us.after === "string") {
        const ai = result.findIndex((s) => s.name === us.after);
        if (ai >= 0)
          pos = ai + 1;
      } else if (typeof us.before === "string") {
        const bi = result.findIndex((s) => s.name === us.before);
        if (bi >= 0)
          pos = bi;
      } else if (typeof us.with === "string") {
        const wi = result.findIndex((s) => s.name === us.with);
        if (wi >= 0)
          pos = wi + 1;
      }
      result.splice(pos, 0, step);
    }
  }
  return result;
}
function unionAppend(def, user) {
  const result = [...def];
  for (const item of user) {
    const key = JSON.stringify(item);
    if (!result.some((x) => JSON.stringify(x) === key))
      result.push(item);
  }
  return result;
}
var MAX_DEPTH = 64;
function mergeValue(key, defVal, userVal, depth) {
  if (key === "each")
    return defVal !== undefined ? defVal : userVal;
  if (userVal === undefined)
    return defVal;
  if (defVal === undefined)
    return userVal;
  if (isRec(defVal) && isRec(userVal))
    return mergeRec(defVal, userVal, depth + 1);
  if (Array.isArray(defVal) && Array.isArray(userVal)) {
    return key === "steps" ? mergeSteps(defVal, userVal) : unionAppend(defVal, userVal);
  }
  return userVal;
}
function mergeRec(def, user, depth = 0) {
  if (depth > MAX_DEPTH)
    throw configError(`anchored.yml nests deeper than ${MAX_DEPTH} levels`);
  const out = {};
  for (const k of new Set([...Object.keys(def), ...Object.keys(user)])) {
    out[k] = mergeValue(k, def[k], user[k], depth);
  }
  return out;
}
function merge2(defaultCfg, userCfg) {
  return mergeRec(defaultCfg, userCfg);
}

// src/services/template/template.ts
function createTemplate(deps) {
  const merge3 = deps.merge ?? merge2;
  const validate = (parsed, label) => {
    const r = ConfigSchema.safeParse(parsed ?? {});
    if (!r.success) {
      throw anchoredError("ConfigError", `invalid ${label}: ${r.error.message}`, [
        `fix ${label} to match the anchored.yml schema`
      ]);
    }
    return r.data;
  };
  const defaultCfg = validate(deps.parseYaml(deps.readDefault()), "default template");
  const userRaw = deps.readUser(deps.projectRoot);
  const userCfg = userRaw === undefined ? {} : validate(deps.parseYaml(userRaw), "anchored.yml");
  const merged = merge3(defaultCfg, userCfg);
  return {
    steps(tier, stage) {
      const block = merged[tier]?.[stage] ?? {};
      const plan = { tier, stage, steps: block.steps ?? [] };
      if (stage === "build") {
        if (block.each !== undefined)
          plan.each = block.each;
        if (block.stop !== undefined)
          plan.stop = block.stop;
        if (block.retry_limit !== undefined)
          plan.retry_limit = block.retry_limit;
      }
      return plan;
    },
    fields(tier) {
      const f = merged[tier]?.fields ?? {};
      return Object.fromEntries(Object.entries(f).map(([k, v]) => [k, String(v)]));
    },
    validate() {
      const tiers = Object.fromEntries(tierNames.map((t) => [t, STAGES.filter((s) => merged[t]?.[s] !== undefined)]));
      const fields = Object.fromEntries(tierNames.map((t) => [t, Object.keys(merged[t]?.fields ?? {})]));
      return { ok: true, tiers, fields };
    },
    raw() {
      return merged;
    }
  };
}

// src/modules/shared/dispatch.ts
function dispatch(tier, nodeVerbs, collections, get) {
  const surface = () => [
    ...Object.keys(nodeVerbs),
    ...Object.entries(collections).flatMap(([c, ops]) => Object.keys(ops).map((op) => `${c} ${op}`))
  ];
  return {
    tier,
    verbs: surface,
    get: (slug) => get(slug),
    run: async (verb, args) => {
      const col = collections[verb];
      if (col) {
        const [op, ...rest] = args;
        if (op === undefined) {
          throw anchoredError("NoOp", `'${tier} ${verb}' needs an op`, [
            `ops: ${Object.keys(col).join(", ")}`
          ]);
        }
        const fn2 = col[op];
        if (!fn2) {
          throw anchoredError("UnknownOp", `'${tier} ${verb}' has no op '${op}'`, [
            `ops: ${Object.keys(col).join(", ")}`
          ]);
        }
        return fn2(...rest);
      }
      const fn = nodeVerbs[verb];
      if (!fn) {
        throw anchoredError("UnknownVerb", `${tier} has no verb '${verb}'`, [
          `known: ${surface().join(", ")}`
        ]);
      }
      return fn(...args);
    }
  };
}

// src/modules/shared/transitions.ts
var lifecycleTransitions = {
  plan: ["drafted"],
  drafted: ["refined", "build"],
  refined: ["build", "drafted"],
  build: ["wrap", "done", "drafted"],
  wrap: ["done", "drafted"],
  done: ["drafted"]
};
var phaseTransitions = {
  pending: ["in-progress"],
  "in-progress": ["done", "blocked", "deferred"],
  blocked: ["in-progress"],
  done: [],
  deferred: []
};
function assertTransition(transitions, from, to, tier = "node") {
  if (from === to)
    return;
  const allowed = transitions[from] ?? [];
  if (!allowed.includes(to)) {
    throw anchoredError("InvalidTransition", `illegal ${tier} transition: ${from} → ${to}`, allowed.length > 0 ? [...allowed] : ["(terminal state — no further transitions)"]);
  }
}

// src/modules/shared/children.ts
var ACTIVE = new Set(["in-progress", "active"]);
function nextChild(children) {
  const active = children.find((c) => ACTIVE.has(c.status));
  if (active)
    return active;
  const done = new Set(children.filter((c) => c.status === "done").map((c) => c.slug));
  for (const c of children) {
    if (c.status === "pending" && (c.depends_on ?? []).every((d) => done.has(d)))
      return c;
  }
  return null;
}
function readyChildren(children) {
  const done = new Set(children.filter((c) => c.status === "done").map((c) => c.slug));
  return children.filter((c) => c.status === "pending" && (c.depends_on ?? []).every((d) => done.has(d)));
}
function addChild(children, child) {
  if (children.some((c) => c.slug === child.slug)) {
    throw anchoredError("DuplicateSlug", `child '${child.slug}' already exists`);
  }
  return [...children, child];
}

// src/modules/shared/questions.ts
function addQuestion(questions, init, idPrefix = "q") {
  const q = {
    id: `${idPrefix}${questions.length + 1}`,
    text: init.text,
    priority: init.priority,
    status: "open"
  };
  if (init.origin !== undefined)
    q.origin = init.origin;
  return [...questions, q];
}
function assertNoOpenQuestions(questions, tier = "node") {
  const open = questions.filter((q) => q.status === "open");
  if (open.length > 0) {
    throw anchoredError("QuestionsOpen", `cannot advance ${tier} to build: ${open.length} open question(s) — ${open.map((q) => `${q.id} (${q.priority})`).join(", ")}`, ["resolve every open question first (the refine walk does this)"]);
  }
}
function resolveQuestion(questions, id, resolution) {
  if (resolution.source === "ai" && !(resolution.reasoning ?? "").trim()) {
    throw anchoredError("MissingReasoning", `an AI-resolved question requires reasoning (q '${id}')`, ['pass reasoning: anchored <tier> question resolve <slug> <id> <answer> ai "<why>"']);
  }
  return questions.map((q) => q.id === id ? {
    ...q,
    status: "resolved",
    answer: resolution.answer,
    source: resolution.source,
    ...resolution.reasoning !== undefined ? { reasoning: resolution.reasoning } : {}
  } : q);
}

// src/modules/shared/log.ts
function appendLog(log, entry) {
  return [...log, entry];
}

// src/modules/shared/statuses.ts
var lifecycleStatusValues = [
  "plan",
  "drafted",
  "refined",
  "build",
  "wrap",
  "done"
];
var phaseStatusValues = ["pending", "in-progress", "done", "blocked", "deferred"];
var stubStatusValues = ["pending", "active", "done", "blocked"];

// src/modules/shared/evidence.ts
function isEvidenceFilled(evidence) {
  if (!Array.isArray(evidence))
    return false;
  return evidence.some((e) => typeof e === "string" && e.trim() !== "" && e.trim() !== "—");
}

// src/modules/shared/fragments.schemas.ts
var KebabSlug = exports_external.string().regex(/^[a-z0-9]+(?:-[a-z0-9]+)*$/, { error: "must be kebab-case (a-z0-9, dash-separated)" });
var NestedSlug = exports_external.string().regex(/^[a-z0-9]+(?:-[a-z0-9]+)*(?:\/[a-z0-9]+(?:-[a-z0-9]+)*)?$/, {
  error: "must be a kebab slug, optionally nested as <epic>/<slug>"
});
var Rule = exports_external.strictObject({ path: exports_external.string(), why: exports_external.string() });
var AcStatus = exports_external.enum(["pending", "done", "deferred"]);
var isReasonFilled = (reason) => typeof reason === "string" && reason.trim() !== "";
var AcceptanceCriterion = exports_external.strictObject({
  id: exports_external.string(),
  text: exports_external.string(),
  status: AcStatus,
  evidence: exports_external.array(exports_external.string()).optional(),
  failures: exports_external.array(exports_external.string()).optional(),
  reason: exports_external.string().optional()
}).refine((ac) => ac.status !== "done" || isEvidenceFilled(ac.evidence), {
  error: "an acceptance criterion with status 'done' must have non-empty evidence"
}).refine((ac) => ac.status !== "deferred" || isReasonFilled(ac.reason), {
  error: "an acceptance criterion with status 'deferred' must have a non-empty reason"
});
var AcceptanceItem = exports_external.strictObject({
  id: exports_external.string(),
  text: exports_external.string(),
  status: AcStatus,
  evidence: exports_external.array(exports_external.string()).optional(),
  reason: exports_external.string().optional()
}).refine((a) => a.status !== "done" || isEvidenceFilled(a.evidence), {
  error: "a definition-of-done item with status 'done' must have non-empty delivery evidence"
}).refine((a) => a.status !== "deferred" || isReasonFilled(a.reason), {
  error: "a definition-of-done item with status 'deferred' must have a non-empty reason"
});
var QuestionSchema = exports_external.strictObject({
  id: exports_external.string(),
  text: exports_external.string(),
  priority: exports_external.enum(["low", "medium", "high"]),
  origin: exports_external.string().optional(),
  status: exports_external.enum(["open", "resolved"]),
  answer: exports_external.string().optional(),
  source: exports_external.enum(["user", "ai"]).optional(),
  reasoning: exports_external.string().optional(),
  phase: exports_external.string().optional()
});
var LogEntrySchema = exports_external.strictObject({
  at: exports_external.string(),
  kind: exports_external.string(),
  note: exports_external.string()
});
var ContextTrails = exports_external.strictObject({
  plan: exports_external.string().optional(),
  refine: exports_external.string().optional(),
  build: exports_external.string().optional(),
  wrap: exports_external.string().optional()
});

// src/modules/phase/phase.schemas.ts
var PhaseStatus = exports_external.enum(phaseStatusValues);
var PhaseNodeSchema = exports_external.strictObject({
  name: exports_external.string(),
  slug: KebabSlug,
  status: PhaseStatus,
  context: exports_external.string().optional(),
  rules: exports_external.array(Rule).optional(),
  acceptance_criteria: exports_external.array(AcceptanceCriterion).optional(),
  evidence: exports_external.array(exports_external.string()).optional(),
  failures: exports_external.array(exports_external.string()).optional(),
  depends_on: exports_external.array(KebabSlug).optional()
});

// src/modules/task/task.schemas.ts
var TaskStatus = exports_external.enum(lifecycleStatusValues);
var TaskNodeSchema = exports_external.strictObject({
  schema_version: exports_external.number().int(),
  slug: NestedSlug,
  title: exports_external.string(),
  created: exports_external.string().optional(),
  status: TaskStatus,
  context: ContextTrails.optional(),
  questions: exports_external.array(QuestionSchema).optional(),
  concerns: exports_external.array(QuestionSchema).optional(),
  log: exports_external.array(LogEntrySchema).optional(),
  phases: exports_external.array(PhaseNodeSchema).optional()
});

// src/modules/task/task.ts
function assertTaskCompletable(node) {
  const openConcerns = (node.concerns ?? []).filter((c) => c.status !== "resolved");
  if (openConcerns.length > 0) {
    throw anchoredError("ConcernsOpen", `cannot complete: ${openConcerns.length} open concern(s) — ${openConcerns.map((c) => c.id).join(", ")}`, ["resolve them in the wrap concern-walk"]);
  }
  const open = (node.phases ?? []).filter((p) => !["done", "deferred"].includes(p.status));
  if (open.length > 0) {
    throw anchoredError("ChildrenIncomplete", `cannot complete: phases not terminal — ${open.map((p) => `${p.slug}:${p.status}`).join(", ")}`, ["finish or defer them first (deferred phases do not block)"]);
  }
}
var RESERVED = new Set([
  "status",
  "phases",
  "questions",
  "concerns",
  "log",
  "schema_version",
  "slug"
]);
function setNested(obj, path, value) {
  const [head, ...rest] = path;
  if (rest.length === 0)
    return { ...obj, [head]: value };
  const cur = obj[head];
  const child = cur && typeof cur === "object" ? cur : {};
  return { ...obj, [head]: setNested(child, rest, value) };
}
function createTask(deps) {
  const { store, template } = deps;
  const read = (slug) => store.read(slug, TaskNodeSchema);
  const write = (slug, node) => store.write(slug, node, TaskNodeSchema);
  const stagePlan = async (stage, slug) => ({
    ...template.steps("task", stage),
    node: await read(slug)
  });
  const nodeVerbs = {
    get: (slug) => read(slug),
    create: (slug, title) => write(slug, {
      schema_version: 2,
      slug,
      title: title ?? slug,
      status: "plan"
    }),
    plan: (slug) => stagePlan("plan", slug),
    refine: (slug) => stagePlan("refine", slug),
    build: (slug) => stagePlan("build", slug),
    wrap: (slug) => stagePlan("wrap", slug),
    async status(slug, to) {
      const node = await read(slug);
      assertTransition(lifecycleTransitions, node.status, to, "task");
      if (to === "build")
        assertNoOpenQuestions(node.questions ?? [], "task");
      if (to === "done")
        assertTaskCompletable(node);
      return write(slug, { ...node, status: to });
    },
    async set(slug, field, value) {
      const top = field.split(".")[0];
      if (RESERVED.has(top)) {
        throw anchoredError("ReservedField", `field '${top}' is reserved and cannot be set via set`, ["use the dedicated verb (status, phase add, question add, …)"]);
      }
      const node = await read(slug);
      const path = field.split(".");
      const next = path.length > 1 ? setNested(node, path, value) : { ...node, [field]: value };
      return write(slug, next);
    },
    async archive(slug) {
      await store.archive(slug);
      return { slug, archived: true };
    },
    async reset(slug) {
      await store.remove(slug);
      return { slug, reset: true };
    }
  };
  const collections = {
    phase: {
      async add(slug, phaseSlug, name) {
        const node = await read(slug);
        const phases = node.phases ?? [];
        if (phases.some((p) => p.slug === phaseSlug)) {
          throw anchoredError("DuplicateSlug", `phase '${phaseSlug}' already exists`);
        }
        const phase = { slug: phaseSlug, name: name ?? phaseSlug, status: "pending" };
        return write(slug, { ...node, phases: [...phases, phase] });
      },
      async list(slug) {
        return (await read(slug)).phases ?? [];
      },
      async next(slug) {
        const phases = (await read(slug)).phases ?? [];
        return nextChild(phases);
      },
      async ready(slug) {
        const phases = (await read(slug)).phases ?? [];
        return readyChildren(phases);
      }
    },
    question: {
      async add(slug, text, priority) {
        const node = await read(slug);
        const questions = addQuestion(node.questions ?? [], {
          text,
          priority: priority ?? "medium"
        });
        return write(slug, { ...node, questions });
      },
      async resolve(slug, id, answer, source, reasoning) {
        const node = await read(slug);
        const questions = resolveQuestion(node.questions ?? [], id, {
          answer,
          source: source ?? "user",
          ...reasoning !== undefined ? { reasoning } : {}
        });
        return write(slug, { ...node, questions });
      }
    },
    concern: {
      async add(slug, text, priority) {
        const node = await read(slug);
        const concerns = addQuestion(node.concerns ?? [], {
          text,
          priority: priority ?? "medium"
        }, "c");
        return write(slug, { ...node, concerns });
      },
      async resolve(slug, id, answer, source, reasoning) {
        const node = await read(slug);
        const concerns = resolveQuestion(node.concerns ?? [], id, {
          answer,
          source: source ?? "user",
          ...reasoning !== undefined ? { reasoning } : {}
        });
        return write(slug, { ...node, concerns });
      }
    },
    log: {
      async add(slug, at, kind, note) {
        const node = await read(slug);
        return write(slug, {
          ...node,
          log: appendLog(node.log ?? [], { at, kind, note })
        });
      }
    }
  };
  return dispatch("task", nodeVerbs, collections, (slug) => read(slug));
}

// src/modules/shared/acceptance.ts
function nextAcId(acs) {
  const max = acs.reduce((m, ac) => {
    const n = /^a(\d+)$/.exec(ac.id);
    return n ? Math.max(m, Number(n[1])) : m;
  }, 0);
  return `a${max + 1}`;
}
function retireFailures(ac) {
  if (!("failures" in ac))
    return ac;
  const { failures: _drop, ...rest } = ac;
  return rest;
}
function addAc(acs, text, id) {
  const acId = id ?? nextAcId(acs);
  if (acs.some((a) => a.id === acId))
    throw anchoredError("DuplicateAc", `ac '${acId}' already exists`);
  return [...acs, { id: acId, text, status: "pending" }];
}
var mapAc = (acs, acId, fn) => {
  if (!acs.some((a) => a.id === acId)) {
    throw anchoredError("UnknownAc", `no acceptance criterion '${acId}'`);
  }
  return acs.map((a) => a.id === acId ? fn(a) : a);
};
function evidenceAc(acs, acId, proof) {
  return mapAc(acs, acId, (ac) => retireFailures({ ...ac, evidence: [...ac.evidence ?? [], proof], status: "done" }));
}
function failAc(acs, acId, why) {
  return mapAc(acs, acId, (ac) => ({
    ...ac,
    failures: [...ac.failures ?? [], why],
    status: "pending"
  }));
}
function doneAc(acs, acId) {
  return mapAc(acs, acId, (ac) => retireFailures({ ...ac, status: "done" }));
}
function setAcText(acs, acId, text) {
  if (!(text && text.trim())) {
    throw anchoredError("AcNoText", `cannot set '${acId}' text to empty`, [
      "pass the new wording: ac set <slug> <id> text '<text>'"
    ]);
  }
  return mapAc(acs, acId, (ac) => ({ ...ac, text }));
}
function deferAc(acs, acId, reason) {
  if (!(reason && reason.trim())) {
    throw anchoredError("AcNoReason", `cannot defer '${acId}' without a reason`, [
      'pass why it is postponed: ac defer <slug> <ac-id> "<reason>"'
    ]);
  }
  return mapAc(acs, acId, (ac) => retireFailures({ ...ac, status: "deferred", reason }));
}

// src/modules/phase/phase.ts
function createPhase(deps) {
  const { store, taskSchema } = deps;
  const split = (slug) => {
    const i = slug.lastIndexOf("/");
    if (i < 0) {
      throw anchoredError("BadSlug", `a phase slug is '<task>/<phase>' (got '${slug}')`, [
        "address a phase under its task, e.g. my-epic/login/setup"
      ]);
    }
    return { taskSlug: slug.slice(0, i), phaseSlug: slug.slice(i + 1) };
  };
  const findPhase = (task, phaseSlug, taskSlug) => {
    const phases = task.phases ?? [];
    const idx = phases.findIndex((p) => p.slug === phaseSlug);
    if (idx < 0)
      throw anchoredError("UnknownPhase", `no phase '${phaseSlug}' in '${taskSlug}'`);
    return { phases, idx };
  };
  const mutate = async (slug, fn) => {
    const { taskSlug, phaseSlug } = split(slug);
    const task = await store.read(taskSlug, taskSchema);
    const { phases, idx } = findPhase(task, phaseSlug, taskSlug);
    const next = fn(phases[idx]);
    return store.write(taskSlug, { ...task, phases: phases.map((p, i) => i === idx ? next : p) }, taskSchema);
  };
  const onAcs = (slug, fn) => mutate(slug, (phase) => ({
    ...phase,
    acceptance_criteria: fn(phase.acceptance_criteria ?? [])
  }));
  const nodeVerbs = {
    async get(slug) {
      const { taskSlug, phaseSlug } = split(slug);
      const task = await store.read(taskSlug, taskSchema);
      return (task.phases ?? []).find((p) => p.slug === phaseSlug) ?? null;
    },
    status: (slug, to) => mutate(slug, (phase) => {
      assertTransition(phaseTransitions, phase.status, to, "phase");
      if (to === "done") {
        const open = (phase.acceptance_criteria ?? []).filter((a) => !["done", "deferred"].includes(a.status));
        if (open.length > 0) {
          throw anchoredError("PhaseIncomplete", `cannot mark '${phase.slug}' done: acceptance criteria not terminal — ${open.map((a) => a.id).join(", ")}`, ["evidence each AC (ac evidence flips it done) or defer it with a reason (ac defer)"]);
        }
      }
      return { ...phase, status: to };
    }),
    set: (slug, field, value) => mutate(slug, (phase) => {
      if (["status", "acceptance_criteria", "rules", "slug"].includes(field)) {
        throw anchoredError("ReservedField", `phase field '${field}' is reserved`, [
          "use the dedicated verb (status, ac add, rule add)"
        ]);
      }
      if (field === "depends_on") {
        return {
          ...phase,
          depends_on: value.split(",").map((s) => s.trim()).filter(Boolean)
        };
      }
      return { ...phase, [field]: value };
    })
  };
  const collections = {
    ac: {
      add: (slug, text, id) => onAcs(slug, (acs) => addAc(acs, text, id)),
      evidence: (slug, acId, text) => onAcs(slug, (acs) => evidenceAc(acs, acId, text)),
      fail: (slug, acId, text) => onAcs(slug, (acs) => failAc(acs, acId, text)),
      defer: (slug, acId, reason) => onAcs(slug, (acs) => deferAc(acs, acId, reason)),
      done: (slug, acId) => onAcs(slug, (acs) => doneAc(acs, acId)),
      set: (slug, acId, field, value) => {
        if (field !== "text") {
          throw anchoredError("AcFieldReserved", `only an AC's 'text' is settable (got '${field}')`, ["edit wording with: phase ac set <slug> <id> text '<new text>'"]);
        }
        return onAcs(slug, (acs) => setAcText(acs, acId, value));
      }
    },
    rule: {
      add: (slug, path, why) => mutate(slug, (phase) => {
        const rules = phase.rules ?? [];
        const next = rules.some((r) => r.path === path) ? rules.map((r) => r.path === path ? { path, why } : r) : [...rules, { path, why }];
        return { ...phase, rules: next };
      })
    }
  };
  return dispatch("phase", nodeVerbs, collections, (slug) => nodeVerbs.get(slug));
}

// src/modules/epic/epic.schemas.ts
var EpicStatus = exports_external.enum(lifecycleStatusValues);
var TaskStub = exports_external.strictObject({
  slug: KebabSlug,
  goal: exports_external.string().optional(),
  status: exports_external.enum(stubStatusValues),
  depends_on: exports_external.array(KebabSlug).optional(),
  acceptance_criteria: exports_external.array(AcceptanceCriterion).optional()
});
var EpicNodeSchema = exports_external.strictObject({
  schema_version: exports_external.number().int(),
  slug: KebabSlug,
  title: exports_external.string(),
  status: EpicStatus,
  created: exports_external.string().optional(),
  goal: exports_external.string().optional(),
  context: ContextTrails.optional(),
  acceptance: exports_external.array(AcceptanceItem).optional(),
  questions: exports_external.array(QuestionSchema).optional(),
  concerns: exports_external.array(QuestionSchema).optional(),
  tasks: exports_external.array(TaskStub).optional(),
  log: exports_external.array(LogEntrySchema).optional()
});

// src/modules/epic/epic.ts
function assertEpicCompletable(node) {
  const open = (node.concerns ?? []).filter((c) => c.status !== "resolved");
  if (open.length > 0) {
    throw anchoredError("ConcernsOpen", `cannot complete: ${open.length} open concern(s)`, [
      "resolve them at wrap"
    ]);
  }
  const stubs = (node.tasks ?? []).filter((t) => t.status !== "done");
  if (stubs.length > 0) {
    throw anchoredError("ChildrenIncomplete", `cannot complete: task-stubs not done — ${stubs.map((s) => s.slug).join(", ")}`, ["finish every task-stub first"]);
  }
  const acc = (node.acceptance ?? []).filter((a) => !["done", "deferred"].includes(a.status));
  if (acc.length > 0) {
    throw anchoredError("AcceptanceIncomplete", `cannot complete: DoD items not terminal — ${acc.map((a) => a.id).join(", ")}`, ["roll up + flip each acceptance item with delivery evidence (or defer it with a reason)"]);
  }
}
var RESERVED2 = new Set([
  "status",
  "tasks",
  "acceptance",
  "questions",
  "concerns",
  "log",
  "schema_version",
  "slug"
]);
var nextEid = (items) => `e${items.reduce((m, a) => Math.max(m, Number(/^e(\d+)$/.exec(a.id)?.[1] ?? 0)), 0) + 1}`;
function setNested2(obj, path, value) {
  const [head, ...rest] = path;
  if (rest.length === 0)
    return { ...obj, [head]: value };
  const cur = obj[head];
  const child = cur && typeof cur === "object" ? cur : {};
  return { ...obj, [head]: setNested2(child, rest, value) };
}
function createEpic(deps) {
  const { store, template, task } = deps;
  const read = (slug) => store.read(slug, EpicNodeSchema);
  const write = (slug, node) => store.write(slug, node, EpicNodeSchema);
  const stubsOf = (n) => n.tasks ?? [];
  const stagePlan = async (stage, slug) => ({
    ...template.steps("epic", stage),
    node: await read(slug)
  });
  const mutateStub = (slug, childSlug, fn) => read(slug).then((node) => {
    const stubs = stubsOf(node);
    const idx = stubs.findIndex((s) => s.slug === childSlug);
    if (idx < 0)
      throw anchoredError("UnknownChild", `no task-stub '${childSlug}'`);
    return write(slug, { ...node, tasks: stubs.map((s, i) => i === idx ? fn(s) : s) });
  });
  const childAc = {
    add: (slug, childSlug, text) => mutateStub(slug, childSlug, (s) => ({
      ...s,
      acceptance_criteria: addAc(s.acceptance_criteria ?? [], text)
    })),
    evidence: (slug, childSlug, acId, proof) => mutateStub(slug, childSlug, (s) => ({
      ...s,
      acceptance_criteria: evidenceAc(s.acceptance_criteria ?? [], acId, proof)
    })),
    fail: (slug, childSlug, acId, why) => mutateStub(slug, childSlug, (s) => ({
      ...s,
      acceptance_criteria: failAc(s.acceptance_criteria ?? [], acId, why)
    })),
    defer: (slug, childSlug, acId, reason) => mutateStub(slug, childSlug, (s) => ({
      ...s,
      acceptance_criteria: deferAc(s.acceptance_criteria ?? [], acId, reason)
    }))
  };
  const nodeVerbs = {
    get: (slug) => read(slug),
    create: (slug, title) => write(slug, {
      schema_version: 2,
      slug,
      title: title ?? slug,
      status: "plan",
      tasks: []
    }),
    plan: (slug) => stagePlan("plan", slug),
    refine: (slug) => stagePlan("refine", slug),
    build: (slug) => stagePlan("build", slug),
    wrap: (slug) => stagePlan("wrap", slug),
    async status(slug, to) {
      const node = await read(slug);
      assertTransition(lifecycleTransitions, node.status, to, "epic");
      if (to === "build")
        assertNoOpenQuestions(node.questions ?? [], "epic");
      if (to === "done")
        assertEpicCompletable(node);
      return write(slug, { ...node, status: to });
    },
    async set(slug, field, value) {
      const path = field.split(".");
      if (RESERVED2.has(path[0]))
        throw anchoredError("ReservedField", `field '${field}' is reserved`);
      const node = await read(slug);
      const next = path.length > 1 ? setNested2(node, path, value) : { ...node, [field]: value };
      return write(slug, next);
    },
    async archive(slug) {
      const node = await read(slug).catch(() => {
        return;
      });
      const delivered = (node?.tasks ?? []).filter((t) => t.status === "done").map((t) => `${slug}/${t.slug}`);
      await store.archive(slug);
      return { slug, archived: true, children: delivered };
    },
    async reset(slug) {
      await store.remove(slug);
      return { slug, reset: true };
    }
  };
  const collections = {
    child: {
      async add(slug, childSlug, goal) {
        const node = await read(slug);
        const stub = {
          slug: childSlug,
          status: "pending",
          ...goal !== undefined ? { goal } : {}
        };
        return write(slug, { ...node, tasks: addChild(stubsOf(node), stub) });
      },
      async next(slug) {
        return nextChild(stubsOf(await read(slug)));
      },
      async ready(slug) {
        return readyChildren(stubsOf(await read(slug)));
      },
      status: (slug, childSlug, status) => mutateStub(slug, childSlug, (s) => {
        if (!stubStatusValues.includes(status)) {
          throw anchoredError("InvalidChildStatus", `'${status}' is not a valid task-stub status`, [...stubStatusValues]);
        }
        return { ...s, status };
      }),
      set: (slug, childSlug, field, value) => mutateStub(slug, childSlug, (s) => {
        if (["slug", "status", "acceptance_criteria"].includes(field)) {
          throw anchoredError("ReservedField", `stub field '${field}' is reserved`);
        }
        return {
          ...s,
          [field]: field === "depends_on" ? value.split(",").map((x) => x.trim()) : value
        };
      }),
      ac: (subOp, ...rest) => {
        const fn = childAc[subOp];
        if (!fn) {
          throw anchoredError("UnknownOp", `'epic child ac' has no op '${subOp}'`, [
            `ops: ${Object.keys(childAc).join(", ")}`
          ]);
        }
        return fn(...rest);
      },
      async "roll-up"(slug) {
        const node = await read(slug);
        const children = await Promise.all(stubsOf(node).map(async (s) => {
          const childSlug = `${node.slug}/${s.slug}`;
          let childStatus;
          try {
            childStatus = (await task.get(childSlug)).status ?? "unknown";
          } catch {
            childStatus = "missing";
          }
          return { slug: s.slug, stubStatus: s.status, childStatus };
        }));
        return { epic: node.slug, children, acceptance: node.acceptance ?? [] };
      }
    },
    acceptance: {
      async add(slug, text) {
        const node = await read(slug);
        const items = node.acceptance ?? [];
        return write(slug, {
          ...node,
          acceptance: [...items, { id: nextEid(items), text, status: "pending" }]
        });
      },
      async status(slug, id, status, detail) {
        const node = await read(slug);
        const items = node.acceptance ?? [];
        const item = items.find((a) => a.id === id);
        if (!item)
          throw anchoredError("UnknownAcceptance", `no acceptance item '${id}'`);
        let next;
        if (status === "done") {
          const merged = detail ? [...item.evidence ?? [], detail] : item.evidence;
          if (!(merged && merged.length > 0)) {
            throw anchoredError("AcceptanceNoEvidence", `acceptance item '${id}' cannot be done without delivery evidence`, ['pass provenance: acceptance status <slug> <id> done "<task>/<phase> — delivered"']);
          }
          next = { ...item, status, evidence: merged };
        } else if (status === "deferred") {
          if (!(detail && detail.trim())) {
            throw anchoredError("AcceptanceNoReason", `acceptance item '${id}' cannot be deferred without a reason`, ['pass the reason: acceptance status <slug> <id> deferred "<why postponed>"']);
          }
          next = { ...item, status, reason: detail };
        } else {
          next = { ...item, status };
        }
        return write(slug, { ...node, acceptance: items.map((a) => a.id === id ? next : a) });
      }
    },
    question: {
      async add(slug, text, priority) {
        const node = await read(slug);
        return write(slug, {
          ...node,
          questions: addQuestion(node.questions ?? [], {
            text,
            priority: priority ?? "medium"
          })
        });
      },
      async resolve(slug, id, answer, source, reasoning) {
        const node = await read(slug);
        return write(slug, {
          ...node,
          questions: resolveQuestion(node.questions ?? [], id, {
            answer,
            source: source ?? "user",
            ...reasoning !== undefined ? { reasoning } : {}
          })
        });
      }
    },
    concern: {
      async add(slug, text, priority) {
        const node = await read(slug);
        return write(slug, {
          ...node,
          concerns: addQuestion(node.concerns ?? [], { text, priority: priority ?? "medium" }, "c")
        });
      },
      async resolve(slug, id, answer, source, reasoning) {
        const node = await read(slug);
        return write(slug, {
          ...node,
          concerns: resolveQuestion(node.concerns ?? [], id, {
            answer,
            source: source ?? "user",
            ...reasoning !== undefined ? { reasoning } : {}
          })
        });
      }
    },
    log: {
      async add(slug, at, kind, note) {
        const node = await read(slug);
        return write(slug, { ...node, log: appendLog(node.log ?? [], { at, kind, note }) });
      }
    }
  };
  return dispatch("epic", nodeVerbs, collections, (slug) => read(slug));
}

// src/cli/scope/next-hint.ts
var isObj = (v) => typeof v === "object" && v !== null && !Array.isArray(v);
function stageHint(status) {
  const fwd = (lifecycleTransitions[status] ?? []).filter((s) => s !== "drafted");
  return fwd.length > 0 ? `status → ${fwd.join(" | ")}` : undefined;
}
function childHint(label, children) {
  const next = nextChild(children);
  if (!next) {
    const open = children.filter((c) => !["done", "deferred"].includes(c.status));
    return open.length === 0 && children.length > 0 ? `all ${label} terminal` : undefined;
  }
  const ready = readyChildren(children).map((c) => c.slug);
  const batch = ready.length > 1 ? ` (ready: ${ready.join(", ")})` : "";
  return `${label} → ${next.slug}${batch}`;
}
function acHint(acs) {
  const open = acs.filter((a) => !["done", "deferred"].includes(a.status)).map((a) => a.id);
  return open.length > 0 ? `evidence: ${open.join(", ")}` : undefined;
}
function nextHint(result) {
  if (!isObj(result))
    return;
  const node = result;
  const subject = isObj(node.node) ? node.node : node;
  if (Array.isArray(subject.acceptance_criteria)) {
    const ac = acHint(subject.acceptance_criteria);
    if (ac)
      return ac;
    const edges = subject.status ? phaseTransitions[subject.status] : undefined;
    if (edges)
      return edges.length > 0 ? `status → ${edges.join(" | ")}` : "phase terminal";
  }
  if (Array.isArray(subject.phases)) {
    const child = childHint("phase", subject.phases);
    if (child && !child.startsWith("all"))
      return child;
    if (subject.status)
      return stageHint(subject.status) ?? child;
    return child;
  }
  if (Array.isArray(subject.tasks)) {
    const child = childHint("child", subject.tasks);
    if (child && !child.startsWith("all"))
      return child;
    if (subject.status)
      return stageHint(subject.status) ?? child;
    return child;
  }
  if (typeof subject.status === "string" && lifecycleTransitions[subject.status])
    return stageHint(subject.status);
  return;
}

// src/cli/envelope.ts
function envelope(command, result, error51) {
  if (error51 !== undefined) {
    const e = error51;
    return {
      ok: false,
      command,
      error: {
        name: e.kind ?? e.name ?? "Error",
        message: e.message ?? String(error51),
        ...e.suggestions ? { suggestions: e.suggestions } : {}
      }
    };
  }
  const next = nextHint(result);
  return { ok: true, command, ...next ? { next } : {}, result: result ?? null };
}

// src/cli/scope/render-line.ts
var isObj2 = (v) => typeof v === "object" && v !== null && !Array.isArray(v);
function val(v) {
  if (v === null || v === undefined)
    return "";
  if (typeof v === "string" || typeof v === "number" || typeof v === "boolean")
    return String(v);
  return JSON.stringify(v);
}
function summarize(result) {
  if (result === null || result === undefined)
    return "ok";
  if (!isObj2(result))
    return val(result);
  const r = result;
  const parts = [];
  if (isObj2(r.node) && (r.stage || r.steps)) {
    if (r.stage)
      parts.push(`stage: ${val(r.stage)}`);
    const n = r.node;
    if (n.slug)
      parts.push(`node: ${val(n.slug)}`);
    if (n.status)
      parts.push(`status: ${val(n.status)}`);
    if (Array.isArray(r.steps))
      parts.push(`steps: ${r.steps.length}`);
    return parts.join(" · ");
  }
  if (r.slug)
    parts.push(`slug: ${val(r.slug)}`);
  if (r.status)
    parts.push(`status: ${val(r.status)}`);
  if (r.archived)
    parts.push("archived");
  if (r.reset)
    parts.push("reset");
  if (Array.isArray(r.phases))
    parts.push(`phases: ${r.phases.length}`);
  if (Array.isArray(r.tasks))
    parts.push(`tasks: ${r.tasks.length}`);
  if (Array.isArray(r.acceptance))
    parts.push(`acceptance: ${r.acceptance.length}`);
  if (Array.isArray(r.acceptance_criteria))
    parts.push(`ac: ${r.acceptance_criteria.length}`);
  if (Array.isArray(r.children))
    parts.push(`children: ${r.children.map((c) => val(c)).join(", ")}`);
  if (parts.length > 0)
    return parts.join(" · ");
  return JSON.stringify(r);
}
function renderLine(env) {
  if (!env.ok) {
    const e = env.error;
    const head = `error[${e?.name ?? "Error"}]: ${e?.message ?? "failed"}`;
    const fix = e?.suggestions && e.suggestions.length > 0 ? ` · fix: ${e.suggestions.join("; ")}` : "";
    return `${env.command} · ${head}${fix}`;
  }
  const body = summarize(env.result);
  const next = env.next ? ` · next: ${env.next}` : "";
  return `${env.command} · ${body}${next}`;
}

// src/cli/scope/exit-code.ts
var USAGE = new Set([
  "UnknownTier",
  "NoVerb",
  "UnknownVerb",
  "NoOp",
  "UnknownOp",
  "BadSlug",
  "ReservedField",
  "AcFieldReserved",
  "InvalidChildStatus"
]);
var NOT_FOUND = new Set([
  "UnknownPhase",
  "UnknownChild",
  "UnknownAcceptance",
  "DuplicateSlug",
  "NotFound",
  "ENOENT"
]);
var GUARD = new Set([
  "InvalidTransition",
  "PhaseIncomplete",
  "ChildrenIncomplete",
  "ConcernsOpen",
  "QuestionsOpen",
  "AcceptanceIncomplete",
  "AcceptanceNoEvidence",
  "AcceptanceNoReason",
  "AcNoReason",
  "AcNoEvidence",
  "ZodError"
]);
function exitCode(env) {
  if (env.ok)
    return 0;
  const name = env.error?.name ?? "Error";
  if (USAGE.has(name))
    return 2;
  if (NOT_FOUND.has(name))
    return 3;
  if (GUARD.has(name))
    return 4;
  return 1;
}

// src/cli/scope/read-stdin-arg.ts
function readStdinArg(rest, readStdin) {
  const i = rest.indexOf("-");
  if (i < 0)
    return rest;
  const body = readStdin();
  return rest.map((a, idx) => idx === i ? body : a);
}

// src/cli/cli.ts
function help(tiers) {
  const lines = [
    "anchored — fractal task lifecycle (plan→refine→build→wrap), CLI-only.",
    "",
    "Usage: anchored <tier> <verb> [slug] [args]   ·   anchored validate | help | version",
    ""
  ];
  for (const [name, t] of Object.entries(tiers))
    lines.push(`  ${name}: ${t.verbs().join(" · ")}`);
  return lines.join(`
`);
}
function createCli(deps) {
  const storeFor = (tier) => createStore({
    fs: deps.fs,
    lock: deps.lock,
    yaml: deps.yaml,
    pathFor: (slug) => deps.pathFor(slug, tier),
    archivePathFor: (slug) => deps.archivePathFor(slug, tier),
    rand: deps.rand,
    pid: deps.pid
  });
  const template = createTemplate({
    readDefault: deps.readDefault,
    readUser: deps.readUser,
    parseYaml: deps.parseYaml,
    projectRoot: deps.projectRoot
  });
  const task = createTask({ store: storeFor("task"), template });
  const phase = createPhase({ store: storeFor("task"), taskSchema: TaskNodeSchema });
  const epic = createEpic({ store: storeFor("epic"), template, task });
  const tiers = { phase, task, epic };
  const emit = (env, json2) => {
    deps.out(json2 ? JSON.stringify(env) : renderLine(env));
    return exitCode(env);
  };
  return {
    template,
    async run(argv) {
      const json2 = argv.includes("--json");
      const [tier, verb, ...rest] = json2 ? argv.filter((a) => a !== "--json") : argv;
      if (tier === undefined || tier === "help" || tier === "--help" || tier === "-h") {
        deps.out(help(tiers));
        return 0;
      }
      if (tier === "version" || tier === "--version" || tier === "-v") {
        deps.out(`anchored ${deps.version ?? "0.0.0"}`);
        return 0;
      }
      if (tier === "validate") {
        try {
          return emit(envelope("validate", template.validate()), json2);
        } catch (e) {
          return emit(envelope("validate", undefined, e), json2);
        }
      }
      const t = tiers[tier];
      if (!t) {
        return emit(envelope(tier, undefined, anchoredError("UnknownTier", `unknown tier '${tier}'`, [
          `tiers: ${Object.keys(tiers).join(", ")}`
        ])), json2);
      }
      if (verb === undefined) {
        return emit(envelope(tier, undefined, anchoredError("NoVerb", `'${tier}' needs a verb`, [`verbs: ${t.verbs().join(", ")}`])), json2);
      }
      const args = readStdinArg(rest, deps.readStdin);
      try {
        return emit(envelope(`${tier} ${verb}`, await t.run(verb, args)), json2);
      } catch (e) {
        return emit(envelope(`${tier} ${verb}`, undefined, e), json2);
      }
    }
  };
}

// src/cli/layout.ts
var ANCHORED_DIR = ".claude/anchored";
function pathFor(root, slug, tier) {
  const base = `${root}/${ANCHORED_DIR}`;
  if (tier === "epic")
    return `${base}/${slug}/_epic.yml`;
  return slug.includes("/") ? `${base}/${slug}.yml` : `${base}/tasks/${slug}.yml`;
}
function archivePathFor(root, slug, tier) {
  const base = `${root}/${ANCHORED_DIR}`;
  if (tier === "epic") {
    return { from: `${base}/${slug}`, to: `${base}/_archive/${slug}` };
  }
  const rel = slug.includes("/") ? slug : `tasks/${slug}`;
  return { from: `${base}/${rel}.yml`, to: `${base}/_archive/${rel}.yml` };
}

// src/bin.ts
var root = process.cwd();
var defaultPath = fileURLToPath(new URL("../default-template/anchored.default.yml", import.meta.url));
var version2 = (() => {
  try {
    const pkg = JSON.parse(readFileSync(fileURLToPath(new URL("../package.json", import.meta.url)), "utf8"));
    return pkg.version ?? "0.0.0";
  } catch {
    return "0.0.0";
  }
})();
var fs = {
  readFile: (p) => readFile(p, "utf8"),
  writeFile: (p, d) => writeFile(p, d),
  rename: (from, to) => rename(from, to),
  unlink: (p) => unlink(p),
  mkdir: (dir, opts) => mkdir(dir, opts),
  stat: async (p) => {
    try {
      const s = await stat(p);
      return `${s.mtimeMs}:${s.size}`;
    } catch {
      return;
    }
  }
};
var sleep = (ms) => new Promise((r) => setTimeout(r, ms));
var lock = {
  async acquire(path) {
    const lockPath = `${path}.lock`;
    const start = Date.now();
    const TIMEOUT = 1e4;
    const STALE = 30000;
    for (;; ) {
      try {
        const fh = await open(lockPath, "wx");
        await fh.writeFile(`${process.pid} ${Date.now()}`);
        await fh.close();
        return async () => {
          try {
            await unlink(lockPath);
          } catch {}
        };
      } catch (e) {
        if (e.code !== "EEXIST")
          throw e;
        try {
          const held = await readFile(lockPath, "utf8");
          const ts = Number(held.split(" ")[1] ?? "0");
          if (Date.now() - ts > STALE) {
            await unlink(lockPath).catch(() => {});
            continue;
          }
        } catch {
          continue;
        }
        if (Date.now() - start > TIMEOUT)
          throw new Error(`lock timeout after ${TIMEOUT}ms`, { cause: e });
        await sleep(15);
      }
    }
  }
};
var cli = createCli({
  fs,
  lock,
  yaml: {
    parse: (raw, o) => $parse(raw, { maxAliasCount: o?.maxAliasCount ?? 100 }),
    stringify: (v, o) => $stringify(v, o)
  },
  pathFor: (slug, tier) => pathFor(root, slug, tier),
  archivePathFor: (slug, tier) => archivePathFor(root, slug, tier),
  rand: () => randomBytes(4).toString("hex"),
  pid: () => process.pid,
  readDefault: () => readFileSync(defaultPath, "utf8"),
  readUser: (r) => {
    const p = `${r}/anchored.yml`;
    if (!existsSync(p))
      return;
    const raw = readFileSync(p, "utf8");
    const MAX = 512 * 1024;
    if (raw.length > MAX) {
      const e = new Error(`anchored.yml is ${raw.length} bytes (> ${MAX}) — likely malformed`);
      e.name = "ConfigError";
      throw e;
    }
    return raw;
  },
  parseYaml: (raw) => $parse(raw, { maxAliasCount: 100 }),
  projectRoot: root,
  out: (line) => process.stdout.write(line + `
`),
  readStdin: () => {
    try {
      return readFileSync(0, "utf8");
    } catch {
      return "";
    }
  },
  version: version2
});
cli.run(process.argv.slice(2)).then((code) => process.exit(code)).catch((err) => {
  const e = err;
  const command = (process.argv[2] ?? "").startsWith("-") ? "" : process.argv[2] ?? "";
  const env = {
    ok: false,
    command,
    error: { name: e.name || "Error", message: e.message || String(err) }
  };
  const json2 = process.argv.includes("--json");
  process.stdout.write((json2 ? JSON.stringify(env) : renderLine(env)) + `
`);
  process.exit(1);
});
