{
  "$ref": "#/definitions/task-file-v2",
  "definitions": {
    "task-file-v2": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "number",
          "const": 2
        },
        "slug": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "status": {
          "type": "string",
          "enum": [
            "plan",
            "drafted",
            "refined",
            "build",
            "wrap",
            "done"
          ]
        },
        "created": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "context": {
          "type": "object",
          "properties": {
            "intro": {
              "type": "string"
            },
            "plan": {
              "type": "string"
            },
            "build": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "wrap": {
              "type": "object",
              "properties": {
                "intro": {
                  "type": "string"
                },
                "subsections": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "required": [
            "intro"
          ],
          "additionalProperties": false
        },
        "phases": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "slug": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[a-z][a-z0-9-]*$"
              },
              "status": {
                "type": "string",
                "enum": [
                  "pending",
                  "in-progress",
                  "done",
                  "blocked",
                  "deferred"
                ]
              },
              "context": {
                "type": "string"
              },
              "rules": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string",
                      "minLength": 1
                    },
                    "why": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "path",
                    "why"
                  ],
                  "additionalProperties": false
                }
              },
              "acceptance_criteria": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "text": {
                      "type": "string",
                      "minLength": 1
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "pending",
                        "done"
                      ]
                    },
                    "evidence": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1
                      },
                      "minItems": 1
                    },
                    "failures": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1
                      },
                      "minItems": 1
                    }
                  },
                  "required": [
                    "text",
                    "status"
                  ],
                  "additionalProperties": false
                },
                "minItems": 1
              },
              "retry_count": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": [
              "name",
              "slug",
              "status",
              "acceptance_criteria"
            ],
            "additionalProperties": true
          }
        },
        "customSections": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "schema_version",
        "slug",
        "status",
        "created",
        "title",
        "context",
        "phases"
      ],
      "additionalProperties": true
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Anchored Task-File (v2)",
  "description": "Schema for anchored task-files (v2 YAML format). Validates the parsed YAML structure: frontmatter, context sections, phases with acceptance criteria, and any user-declared extension fields."
}
